{
    "name": "techforce/openlogs-laravel",
    "description": "Laravel bridge for OpenLogs: a first-class log channel with optional queued delivery, built on techforce/openlogs-monolog.",
    "keywords": ["laravel", "logging", "openlogs", "monolog"],
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "techforce/openlogs-monolog": "*",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/bus": "^11.0|^12.0",
        "illuminate/queue": "^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "TechForce\\OpenLogs\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TechForce\\OpenLogs\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "TechForce\\OpenLogs\\Laravel\\OpenLogsServiceProvider"
            ]
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../openlogs-monolog",
            "options": { "symlink": true }
        }
    ],
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
